%% /conversation/message/stream の処理シーケンス（ストリーミング版）

sequenceDiagram
    participant C as Client
    participant R as Route
    participant S as StreamingConversationService
    participant SR as PracticeSessionRepository
    participant MR as SessionMessageRepository
    participant PR as SessionParticipantRepository
    participant LLM as LLMProvider
    participant TTS as TTSService
    participant DB as Database

    C->>R: POST /conversation/message/stream
    R->>R: Validate ConversationMessageRequest
    Note over R: Response: text/event-stream

    R->>S: StreamingConversationService(db)
    Note over S: Initialize repositories and LLM

    R->>S: process_message_stream(session_id, message, generate_audio)

    S->>SR: get_by_id(session_id)
    SR->>DB: SELECT practice_sessions
    DB-->>SR: PracticeSession
    SR-->>S: session

    S->>S: Validate session status == active

    S->>MR: list_by_session_id(session_id)
    MR->>DB: SELECT session_messages
    DB-->>MR: list of SessionMessage
    MR-->>S: existing_messages

    S->>S: Create user SessionMessage
    S->>MR: create(user_msg)
    MR->>DB: INSERT session_messages
    DB-->>MR: SessionMessage
    MR-->>S: saved_user_msg

    S->>S: _build_conversation_history()

    S->>PR: list_by_session_id(session_id)
    PR->>DB: SELECT session_participants
    DB-->>PR: list of SessionParticipant
    PR-->>S: participants

    S->>S: _pick_random_participant()
    S-->>C: StreamEvent(metadata, {participant_id, speaker_id})

    alt generate_audio == true
        S->>S: _stream_with_tts()
        Note over S: LLM ストリーミング + 並列 TTS 生成

        loop LLM streaming
            S->>LLM: generate_stream(prompt)
            LLM-->>S: LLMStreamChunk
            S-->>C: StreamEvent(text_chunk, {text})

            S->>S: _extract_sentences()
            Note over S: 文の区切りを検出

            opt 完全な文を検出
                par TTS 並列生成
                    S->>TTS: synthesize(sentence, speaker_id)
                    TTS-->>S: TTSResult
                    S-->>C: StreamEvent(audio_chunk, {audio_base64, sequence, text})
                end
            end
        end

        S->>S: 残りの文を TTS 生成
        S->>TTS: synthesize(remaining, speaker_id)
        TTS-->>S: TTSResult
        S-->>C: StreamEvent(audio_chunk, {audio_base64, sequence, text})

    else generate_audio == false
        S->>S: _stream_text_only()
        loop LLM streaming
            S->>LLM: generate_stream(prompt)
            LLM-->>S: LLMStreamChunk
            S-->>C: StreamEvent(text_chunk, {text})
        end
    end

    S->>S: Create AI SessionMessage
    S->>MR: create(ai_msg)
    MR->>DB: INSERT session_messages
    DB-->>MR: SessionMessage
    MR-->>S: saved_ai_msg

    S-->>C: StreamEvent(complete, {text, audio_sequence_count})
    Note over C: SSE 接続を閉じる
