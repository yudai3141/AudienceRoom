APP_ENV=local
APP_HOST=0.0.0.0
APP_PORT=8000

POSTGRES_DB=audienceroom
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_HOST=db
POSTGRES_PORT=5432

DATABASE_URL=postgresql+psycopg://app:app@db:5432/audienceroom

FIREBASE_PROJECT_ID=demo-audienceroom
# Set by docker-compose; override only when running outside Docker
# FIREBASE_AUTH_EMULATOR_HOST=localhost:9099

# LLM Settings
LLM_PROVIDER=gemini
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash
# OPENAI_API_KEY=your-openai-api-key
# OPENAI_MODEL=gpt-4o-mini

# VOICEVOX Settings
VOICEVOX_HOST=voicevox
VOICEVOX_PORT=50021
